       'extra_flags',                 'cmse_flags',                 'cmse_link_flags',                 'iar_lib_link_flags',                 'fpu_flags',                 'fpu_link_flags',                 'debug_flags',                 'as_name',                 'as_com',                 'as_flags',                 'link_name',                 'link_com',                 'link_flags',                 'link_ext',                 'link_script_prefix',                 'lib_prefix',                 'lib_dir_prefix',                 'lib_inc_prefix',                 'lib_inc_suffix',                 'ar_name',                 'ar_com',                 'optimization_levels',                 'extra_env_vars' ]    def __init__(self, toolchain_info):            get_tc_info = lambda item : toolchain_info[item] if toolchain_info[item] is not None else [] # Safe 'get' for tags that don't always have elements            self.name = toolchain_info['name']            self.cc_name = toolchain_info['cc_name']            self.cc_com = toolchain_info['cc_com']            self.cpp_com = toolchain_info['cpp_com']            self.clang_tidy_com = ''            if 'gcc' == self.name:                self.clang_tidy_com = toolchain_info['clang_tidy_com']                if 'fix' == static_analyze:                    self.clang_tidy_com = self.clang_tidy_com.replace('$FIX_OPTION', '-fix')                else:                    self.clang_tidy_com = self.clang_tidy_com.replace('$FIX_OPTION', '-export-fixes=${TARGET}.fix')                self.clang_tidy_com += " -Itest_files/clang_headers"            self.as_name = toolchain_info['as_name']            self.as_com = toolchain_info['as_com']            self.link_name = toolchain_info['link_name']            self.link_com = toolchain_info['link_com']            self.link_ext = toolchain_info['link_ext']            self.lib_prefix = toolchain_info['lib_prefix']            self.lib_dir_prefix = toolchain_info['lib_dir_prefix']            self.lib_inc_prefix = toolchain_info['lib_inc_prefix']            self.lib_inc_suffix = toolchain_info['lib_inc_suffix']            self.link_script_prefix = toolchain_info['link_script_prefix']            self.ar_name = toolchain_info['ar_name']            self.ar_com = toolchain_info['ar_com']            self.common_flags = get_tc_info('common_flags') # Parse flags common to compiler and linker            self.cxx_flags = toolchain_info['cxx_flags'] # Parse flags common to c and cpp            self.c_flags = toolchain_info['c_flags'] # Parse C flags            self.cpp_flags = toolchain_info['cpp_flags'] # Parse CPP flags            self.fsp_flags = toolchain_info['fsp_flags'] # Parse FSP flags            self.third_party_flags = toolchain_info['third_party_flags'] # Parse CC flags for third party code            # This stores the version information of the toolchain. We only want to do this if this toolchain is being used for this build.            tc = GetOption('compiler')            if (tc == None) or (self.name == tc):                version_env = create_env()                # OR with true so this will not fail build jobs if toolchains are not defined in tools_cfg.yml                version_env.Command(self.name + '.version', None, self.cc_name + ' --version > ' + self.name + '.version || true')            self.extra_flags = get_tc_info('extra_flags') # Parse Extra flags            self.debug_flags = toolchain_info['debug_flags'] # Parse Debug flags            self.cmse_flags = toolchain_info['cmse_flags'] # Parse CMSE flags            self.cmse_link_flags = toolchain_info['cmse_link_flags'] # Parse CMSE flags            if 'iar' == self.name:                self.iar_lib_link_flags = toolchain_info['iar_lib_link_flags'] # Parse link flags required for IAR threading support            self.fpu_flags = toolchain_info['fpu_flags'] # Parse FPU flags            self.fpu_link_flags = get_tc_info('fpu_link_flags') # Parse FPU link flags            self.as_flags = toolchain_info['as_flags'] # Parse assembler flags            self.link_flags = toolchain_info['link_flags'] # Parse Linker flags            self.optimization_levels = toolchain_info['optimization_levels'] # Parse optimization levels            self.extra_env_vars = toolchain_info['extra_env_vars'] # Parse any extra environment variables that are needed for this toolchain (ie: 'ARM_TOOL_VARIANT=ult' for AC6)def configure_scons_cache(cache_dir):    # Handle 'None' type input    cache_dir = str(cache_dir)    # Check if scons cache is valid directory. SCons will actually create a cache directory for you. I'm    # not using the path if it does not exist and does not end with 'scons_cache' as I bet that is not    # intended. If it is intended (eg: creating new cache) then create the directory before calling SCons.    basename = os.path.basename(os.path.normpath(cache_dir))    if not os.path.isdir(cache_dir) and 'scons_cache' != basename:        print('ENV: SCons cache directory {}, does not exist.'.format(cache_dir))        cache_dir = ''    if cache_dir != '' and not GetOption('cache_disable'):        # This is set when creating each environment, but print here to avoid spam        print("ENV: SCons cache path: " + cache_dir)    else:        print("ENV: SCons cache disabled")        cache_dir = ''    return cache_dirdef update_global_path():    # Get the XML tree    with open(CONST_TOOLS_CFG_FILE_NAME, 'r') as f:        tools_cfg_dict = yaml.load(f, Loader=yaml.Loader)    # Check if <scons_cache_dir> element is found. If so, record path    global g_scons_cache_dir    g_scons_cache_dir = tools_cfg_dict['scons_cache_dir'] if 'scons_cache_dir' in tools_cfg_dict else None    g_scons_cache_dir = configure_scons_cache(g_scons_cache_dir)    gcc_root = tools_cfg_dict['gcc_install'] if 'gcc_install' in tools_cfg_dict else None    iar_root = tools_cfg_dict['iar_install'] if 'iar_install' in tools_cfg_dict else None    llvm_root = tools_cfg_dict['llvm_install'] if 'llvm_install' in tools_cfg_dict else None    ac6_root = tools_cfg_dict['ac6_install'] if 'ac6_install' in tools_cfg_dict else None    iar_bin_loc = os.path.join(iar_root, 'bin')    gcc_bin_loc = os.path.join(gcc_root, 'bin')    llvm_bin_loc = os.path.join(llvm_root, 'bin')    ac6_bin_loc = os.path.join(ac6_root, 'bin')    print("ENV: IAR 'bin' folder: " + iar_bin_loc)    print("ENV: GCC 'bin' folder: " + gcc_bin_loc)    print("ENV: LLVM 'bin' folder: " + llvm_bin_loc)    print("ENV: AC6 'bin' folder: ", ac6_bin_loc)    clang_tidy_root = tools_cfg_dict['clang_tidy_install'] if 'clang_tidy_install' in tools_cfg_dict else None    if clang_tidy_root is not None:        clang_bin_loc = os.path.join(clang_tidy_root, 'bin')        print("ENV: CLANG folder" + clang_bin_loc)        os.environ['CLANG_ISYSTEM_PATH'] = os.path.join(gcc_root, 'arm-none-eabi','include')    elif static_analyze is not None:        print('ERROR: Clang path must be specified in tools_cfg.yml')        sys.exit(1)    os.environ["PATH"] = iar_bin_loc + os.pathsep + \                         gcc_bin_loc + os.pathsep + \                         llvm_bin_loc + os.pathsep + \                         clang_bin_loc + os.pathsep + \                         ac6_bin_loc + os.pathsep    default_env = DefaultEnvironment(tools = [])def create_env():    # Create dictionary of environment variables    env = Environment(CPPDEFPREFIX = '-D',        OBJSUFFIX = '.o',        INCPREFIX = '-I',        LIBDIRPREFIX = '-L',        PROGSUFFIX = '.elf',        OPTIMIZATION = '-O0',        PROJECT_DIR = CONST_PROJECT_XML_DIR,        tools = ['cxx', 'cc', 'as', 'link', 'ar'],        )    if g_scons_cache_dir != '':        env.CacheDir(g_scons_cache_dir)    if static_analyze is not None:        if CONST_DECLUTTER or env.GetOption('silent'):            env["CLANG_TIDY"] = 'clang-tidy --extra-arg=-fno-caret-diagnostics -quiet'        else:            env["CLANG_TIDY"] = 'clang-tidy'        env["CLANG_ISYSTEM_PATH"] = os.environ['CLANG_ISYSTEM_PATH']    # RA FSP is now using Arm UBL licenses so this env var is no longer used. This env var can still be used    # by setting it on the host system if needed.    if "ARMLMD_LICENSE_FILE" in os.environ:        env["ENV"]["ARMLMD_LICENSE_FILE"] = os.environ["ARMLMD_LICENSE_FILE"]    env.PrependENVPath('PATH', os.environ['PATH'])    if CONST_DECLUTTER:        env["CCCOMSTR"] = "$TARGET"        env["LINKCOMSTR"] = "$TARGET"    return envdef split_macro_list(macro_list):    # Splits a macro list respecting parentheses so arguments can be used in macros.    paren_depth = 0    start_idx = 0    out_list = []    for i in range(0,len(macro_list)):        if macro_list[i] == '(':            paren_depth += 1        elif macro_list[i] == ')':            paren_depth -= 1        elif (macro_list[i] == ',') and (paren_depth == 0):            out_list.append(macro_list[start_idx:i])            start_idx = i + 1    out_list.append(macro_list[start_idx:])    return out_listdef parse_xml_path_append(local_list, item):    local_list.append(item.text)def parse_xml_path(root, xml_path_list, local_list, function=parse_xml_path_append):    tag = xml_path_list.pop(0)    for item in root.findall(tag):        if len(xml_path_list) > 0:            parse_xml_path(item, xml_path_list, local_list, function)        else:            function(local_list, item)def parse_xml_path_dict(local_list, item):    try:        list = item.text.split('=')    except:        list = item.split('=')    if len(list) > 1:        value = list[1]    else:        value = '1'    local_list[list[0]] = value    return local_listdef parse_project(root, project):    project.build_module_source_only = False    if len(root.findall("module_src_only")) > 0:        if 'true' == root.find("module_src_only").text:            project.build_module_source_only = True    project.name = ''    if len(root.findall("name")) > 0:        project.name = root.find("name").text    if len(root.findall("key")) > 0:        project.key = root.find("key").text    if len(root.findall("enc_key")) > 0:        project.enc_key = root.find("enc_key").text    # See if we should create a library for this module. Default is False.    project.create_lib = False    if len(root.findall("create_lib")) > 0:        if "true" == root.find("create_lib").text.lower():            project.create_lib = True    # Parse include directories into the provided list    xml_path_list = ['include_dirs', 'include']    parse_xml_path(root, xml_path_list, project.includes)    # Parse source directories into the provided list    xml_path_list = ['main_dirs', 'src']    parse_xml_path(root, xml_path_list, project.main_dirs)    # Check if we should ignore warnings on main_dirs code. This should only be used    # in exceptional circumstances. For example, if we do not own the code and cannot    # change it.    project.ignore_warnings = False    if root.find('main_dirs') is not None:        if 'ignore_warnings' in root.find('main_dirs').attrib:            if root.find('main_dirs').attrib['ignore_warnings'] == 'true':                project.ignore_warnings = True    # For libraries we only need main_dirs code and ignore test macros    if not project.create_lib:        xml_path_list = ['common_dirs', 'src']        parse_xml_path(root, xml_path_list, project.common_dirs)        xml_path_list = ['test_dirs', 'src']        parse_xml_path(root, xml_path_list, project.test_dirs)        xml_path_list = ['third_party_test_dirs', 'src']        parse_xml_path(root, xml_path_list, project.third_party_test_dirs)        xml_path_list = ['test_macros', 'macro']        parse_xml_path(root, xml_path_list, project.test_macros, parse_xml_path_dict)        # Extract implicit dependencies        project.implicit_dependencies = [re.findall(r'[a-zA-Z0-9_]+\.h',e)[0] for e in project.test_macros.values() if r'.h\"' in e]    xml_path_list = ['no_instrument_files', 'src']    parse_xml_path(root, xml_path_list, project.no_instrument_files)    xml_path_list = ['exclude_dirs', 'exclude']    parse_xml_path(root, xml_path_list, project.exclude_dirs)    project.exclude_dirs = [os.path.normpath(x) for x in project.exclude_dirs]    # Parse macros into the provided dictionary    xml_path_list = ['common_macros', 'macro']    parse_xml_path(root, xml_path_list, project.common_macros, parse_xml_path_dict)    # parse macro configurations    options_list = []    for main_macro_configuration in root.findall('main_macro_configurations/main_macro_configuration'):        options = []        # options_list will be [] the first time through this loop so the else will be hit        for macro in main_macro_configuration.findall('macro'):            options.append((macro.get('name'), split_macro_list(macro.text)))        # If options_list is not empty then we need to combine the multiple main_macro_configuration elements        if options_list:            options_list = list(itertools.product(options_list, options))            merged_options_list = []            for option1, option2 in options_list:                name1, macros1 = option1                name2, macros2 = option2                if name1 and name2:                    merged_name = name1 + '_' + name2                else:                    merged_name = name1 + name2                merged_options_list.append((merged_name, macros1 + macros2))                options_list = merged_options_list        else:            options_list = options    options_dict = {}    for key, macros in options_list:        # Check for 'typical' build        if key == "":            key = 'typical'        macro_dict = {}        for macro in macros:            parse_xml_path_dict(macro_dict, macro)        options_dict[key] = macro_dict    if not options_dict:        options_dict['typical'] = {}    project.main_macro_configurations = options_dict    # Check to see if any framework layer modules are used.  If so, define macros appropriately    project.common_macros['BSP_CFG_RTOS'] = '0'    for src in project.third_party_test_dirs:        # Allow testing of frameworks without ThreadX        if os.path.relpath('threadx') in os.path.relpath(src):            project.common_macros['BSP_CFG_RTOS'] = '1'            break        # Allow testing of frameworks without FreeRTOS        if os.path.relpath('FreeRTOS') in os.path.relpath(src):            project.common_macros['BSP_CFG_RTOS'] = '2'            break    # Parse linker scripts    linker_scripts_local = []    xml_path_list = ['linker_scripts', 'script']    parse_xml_path(root, xml_path_list, linker_scripts_local)    if len(linker_scripts_local) > 0:        project.linker_scripts = linker_scripts_local    # Parse linker paths    xml_path_list = ['linker_paths', 'path']    parse_xml_path(root, xml_path_list, project.linker_paths)    # Parse linker includes    linker_includes_local = []    xml_path_list = ['linker_includes', 'path']    parse_xml_path(root, xml_path_list, linker_includes_local)    if len(linker_includes_local) > 0:        project.linker_includes = linker_includes_local    # Parse secondary linker includes (bootloader XIP app)    secondary_linker_includes_local = []    xml_path_list = ['secondary_linker_includes', 'path']    parse_xml_path(root, xml_path_list, secondary_linker_includes_local)    if len(secondary_linker_includes_local) > 0:        project.secondary_linker_includes = secondary_linker_includes_local    # Parse libraries    xml_path_list = ['libraries', 'library']    parse_xml_path(root, xml_path_list, project.libraries)    # Parse objects    xml_path_list = ['dependencies', 'dependency']    parse_xml_path(root, xml_path_list, project.dependencies)    # Parse board names    xml_path_list = ['boards', 'board']    parse_xml_path(root, xml_path_list, project.boards)    # Parse compilers to skip    xml_path_list = ['skip_compiler', 'compiler']    parse_xml_path(root, xml_path_list, project.skip_compiler)    # Parse target group -> name    target_group_name_local = []    xml_path_list = ['target_group', 'name']    parse_xml_path(root, xml_path_list, target_group_name_local)    # Parse target group -> board id    target_group_board_id_local = []    xml_path_list = ['target_group', 'board_id']    parse_xml_path(root, xml_path_list, target_group_board_id_local)    # If one target group is defined, add it to the project.    if len(target_group_name_local) == 1 and len(target_group_board_id_local) == 1:        project.target_group = {            'name': target_group_name_local[0],            'board_id': target_group_board_id_local[0],        }    # If there is no target group defined, set the target group name to the project name    else:        name = project.name        if project.name == '': # If there is no project name, set it to "default".            name = 'default'        project.target_group = {            'name': name,            'board_id': 'default', # If no target group is defined, set the board_id to "default".        }    # Parse any data to init test info with    if len(root.findall("test_info_init")) > 0:        project.test_info_init = root.find("test_info_init").text    # Parse srec_check segment add objects    srec_action_list = []    xml_path_list = [ 'srec_check', 'segment_add' ]    parse_xml_path(root, xml_path_list, srec_action_list)    for action in srec_action_list:        project.srec_check.append( ('s', action) )    # Parse srec_check segment remove objects    srec_action_list.clear()    xml_path_list = [ 'srec_check', 'segment_remove' ]    parse_xml_path(root, xml_path_list, srec_action_list)    for action in srec_action_list:        project.srec_check.append( ('S', action) )    # Parse srec_check keepout add objects    srec_action_list.clear()    xml_path_list = [ 'srec_check', 'keepout_add' ]    parse_xml_path(root, xml_path_list, srec_action_list)    for action in srec_action_list:        project.srec_check.append( ('k', action) )    # Parse srec_check keepout remove objects    srec_action_list.clear()    xml_path_list = [ 'srec_check', 'keepout_remove' ]    parse_xml_path(root, xml_path_list, srec_action_list)    for action in srec_action_list:        project.srec_check.append( ('K', action) )    custom_cxx_flags_element = root.find('custom_cxx_flags')    if None != custom_cxx_flags_element:        # Comments are included as children of lxml elements. Filter out comments by checking the type.        compiler_elements = filter(lambda x: type(x) == etree._Element, list(custom_cxx_flags_element))        # Get the tag name from each compiler        compilers = list(map(lambda x: x.tag, compiler_elements))        # Iterate over compilers to get custom cxx flags        for compiler in compilers:            xml_path_list = [ 'custom_cxx_flags', compiler, 'flag' ]            cxx_flags = []            parse_xml_path(root, xml_path_list, cxx_flags)            project.custom_cxx_flags[compiler] = cxx_flagsdef configure_tool_environment(env, toolchain, mcu, project, third_party=False):    env["CC"] = toolchain.cc_name    env["CXX"] = toolchain.cc_name    env["AS"] = toolchain.as_name    env["LINK"] = toolchain.link_name    env["AR"] = toolchain.ar_name    env["CCCOM"] = toolchain.cc_com    env["CXXCOM"] = toolchain.cpp_com    env["ASCOM"] = toolchain.as_com    env["LINKCOM"] = toolchain.link_com    env["ARCOM"] = toolchain.ar_com    env["_LINKSCRIPTS"] = '$( ${_concat(LINKSCRIPTPREFIX, LINKSCRIPTS, LINKEXT, __env__, RDirs, TARGET, SOURCE)} $)'    env["_LIBINCFLAGS"] = '$( ${_concat(LIBINCPREFIX, LIBINCPATH, LIBINCSUFFIX, __env__, RDirs, TARGET, SOURCE)} $)'    env["LIBLINKPREFIX"] = toolchain.lib_prefix    env["LIBDIRPREFIX"] = toolchain.lib_dir_prefix    env["LIBINCPREFIX"] = toolchain.lib_inc_prefix    env["LIBINCSUFFIX"] = toolchain.lib_inc_suffix    env["LIBLINKSUFFIX"] = ''    env["CXXFILESUFFIX"] = '.cpp'    cxx_flags = copy.deepcopy(toolchain.cxx_flags)    # FSP and Third Party flags apply to c and c++    if third_party or project.ignore_warnings:        cxx_flags += toolchain.third_party_flags    else:        cxx_flags += toolchain.fsp_flags    if CONST_CORE_FPU_DICT[project.mcu_dict[mcu]]:        # Linker flags apply to C and C++. Dont put flags in common_flags because some linkers do not have FPU flags        cxx_flags = copy.deepcopy(toolchain.fpu_flags) + cxx_flags        env["LINKFLAGS"] = copy.deepcopy(toolchain.link_flags) + toolchain.fpu_link_flags        env["FPU_VERSION"] = CONST_CORE_FPU_DICT[project.mcu_dict[mcu]]    else:        env["LINKFLAGS"] = copy.deepcopy(toolchain.link_flags)    if CONST_CORE_CMSE_DICT[project.mcu_dict[mcu]]:        if 'tz_s' in project.type:            cxx_flags += toolchain.cmse_flags            env["LINKFLAGS"] += toolchain.cmse_link_flags    # If creating lib, do not add debug flags as that will greatly increase size of library    if not project.create_lib and not project.build_module_source_only:        cxx_flags += toolchain.debug_flags    env['CXX_FLAGS'] = cxx_flags + project.custom_cxx_flags[toolchain.name]    env['C_FLAGS'] = toolchain.c_flags    env['CPP_FLAGS'] = toolchain.cpp_flags    env["COMMON_FLAGS"] = toolchain.common_flags    env["ASFLAGS"] = toolchain.as_flags    env["COMPILER"] = toolchain.name    env["COMPILER_UPPER"] = toolchain.name.upper()    if "secondary_core" in CONST_MCU_DICT[mcu]:        # For MCUs with 2 cores linker scripts for basic TZ projects are located under the primary_core subfolder        env["CORE_SUBFOLDER"] = "primary_core/"    else:        env["CORE_SUBFOLDER"] = ""    env["LINKEXT"] = toolchain.link_ext    env["LINKSCRIPTPREFIX"] = toolchain.link_script_prefix    # Add any extra env vars    for key, value in toolchain.extra_env_vars.items():        env["ENV"][key] = valuedef configure_build_rules(env):    # Get global builder and set rule for '.c.template' files to be identical to that of '.c' files    import SCons.Tool    import SCons.Defaults    my_suffix = '.c.template'    static_obj, shared_obj = SCons.Tool.createObjBuilders(env)    static_obj.add_action(my_suffix, SCons.Defaults.CAction)    static_obj.add_emitter(my_suffix, SCons.Defaults.StaticObjectEmitter)def configure_project_environment(env, project):    # Setup project specific environment variables    env["LINKSCRIPTS"] = project.linker_scripts    env["LIBS"] = copy.deepcopy(project.libraries)    env["LIBPATH"] = copy.deepcopy(project.linker_paths)    env["LIBINCPATH"] = copy.deepcopy(project.linker_includes)    # Add include paths    env["CPPPATH"] = project.includesdef configure_build_environment(env, o_level, toolchain, project, board):    # Setup project specific environment variables    try:        level = toolchain.optimization_levels[o_level]        if OPTIMIZATION_OVERRIDE is not None:            level = toolchain.optimization_levels[OPTIMIZATION_OVERRIDE]    except:        print("ERROR: Optimization level " + o_level + " not found in " + toolchain.name + " compiler.")        level = toolchain.optimization_levels['none']    mcu = board.split('_')[0].lower()    env["MCU"] = mcu    core = project.mcu_dict[mcu]    env["CORE"] = core    # First check if this is a multicore tz project type    multicore_tz_match = re.match(r'^((?:primary|secondary)_core)_(tz_(?:s|ns))$', project.type)    if multicore_tz_match:        # Parse into the correct linker path        env["PROJECT_TYPE"] = f"{multicore_tz_match.group(1)}/{multicore_tz_match.group(2)}"    elif 'flat' == project.type:        # If project.type is flat then we use linker files in the base of the folder. This is because when we started        # there was only 'flat' and it was assumed.        env["PROJECT_TYPE"] = ""    else:        env["PROJECT_TYPE"] = project.type    # CONST_CORE_ARM_GCC_85_HACKS_DICT is used here because our clang-tidy version is old enough that it does not know about CM85. So we need to trick it to be CM33    env['CLANG_TIDY_CORE'] = core if (toolchain.name != 'gcc') or (project.mcu_dict[mcu] != '85') else CONST_CORE_ARM_GCC_85_HACKS_DICT['primary_core']    macros = {}    macros.update(project.common_macros)    macros.update({k: v for k, v in [e.split('=') for e in CONST_MCU_DICT[mcu]['macros']]})    # Add board flag    board_macro = board + '_BUILD'    macros[board_macro] = '1'    # Used in tools.yml for clang_tidy and llvm    env["ARM_ARCH"] = CONST_CORE_ARM_ARCH_DICT[project.mcu_dict[mcu]]    # Passed in as common flags from tools.yml    env["ARM_ARCH_FLAGS"] = CONST_CORE_ARM_ARCH_FLAGS_DICT[project.mcu_dict[mcu]]    env["CORE_UPPER"] = core.upper()    env["CORE_SYMBOL"] = core.replace('plus', '+')    env["CPPDEFINES"] = macros    env["OPTIMIZATION"] = level    return macrosdef get_code_size(main_obj_path, cmd_out, parsed_code_sizes, idx):    out = 0    code_sizes = {}    if os.path.exists(main_obj_path):        out = check_output(['arm-none-eabi-size', '--format=berkeley', main_obj_path])        if(CONST_FUNCTION_SIZE):            f = open(main_obj_path+'.code_size', "w")            objdump = check_output(['arm-none-eabi-objdump', '-t', main_obj_path])            f.write(objdump)            f.close()            parse_code_size(main_obj_path+'.code_size', code_sizes)    cmd_out[idx] = out    parsed_code_sizes[idx] = code_sizesdef exit_func():    from SCons.Script import GetBuildFailures    build_failure_objects = GetBuildFailures()    # Add rtt_address to yml file (must be after build completes)    if GetOption('rtt_addr_in_yml'):        for elf_file, _, _, _ in g_project_list:            yaml_file = elf_file.replace('.elf', '.yml')            # Secure projects don't have yml files            if os.path.exists(yaml_file):                with open(yaml_file, 'r') as f:                    yml_dict = yaml.load(f, Loader=yaml.SafeLoader)                nm_output = check_output(['arm-none-eabi-nm', elf_file])                for line in nm_output.decode().split('\n'):                    if ' _SEGGER_RTT' in line:                        yml_dict['rtt_address'] = line.split(' ')[0]                # https://stackoverflow.com/questions/20352794/pyyaml-is-producing-undesired-python-unicode-output/20369984                with open(yaml_file, 'wb') as f:                    f.write(yaml.safe_dump(yml_dict, encoding='utf-8', allow_unicode=True))    # Store the rtt address for each application in test_info.yml. This will be used by fsp_test_parallel.py in order to    # determine the address of the RTT control block.    for root,  subdirs, files in os.walk('build/'):        if 'test_info.yml' in files:            yaml_file = os.path.join(root, 'test_info.yml')            # Load the yml file into a dictionary            with open(yaml_file) as f:                yml_dict = yaml.load(f, Loader=yaml.SafeLoader)            # Loop through the yml file and for each application, get the rtt address.            for target_group in yml_dict:                for build_config in yml_dict[target_group]:                    for project in yml_dict[target_group][build_config]['projects']:                        try:                            # store_symbol_address is an array of symbols that will be search for in the elf.                            # If the symbol is found in the elf, its address will be stored in test_info.yml.                            # These symbol addresses can be used by test scripts.                            # Ex:                            # The rm_mcuboot_port tests specify 'g_pub_key' which is needed to program MCUboot apps.                            # 'g_pub_key': <address> is stored in test_info.yml for use by the MCUboot flashing scripts.                            if 'store_symbol_address' in project:                                application_elf = project['application']                                application_elf = application_elf.replace('.srec', '.elf')                                # Execute readelf command to get the address of project['store_symbol_address']                                command_output = str(check_output(['arm-none-eabi-readelf', '-s', application_elf]))                                symbol_addresses = {}                                for symbol in project['store_symbol_address']:                                    # Filter the output to lines that include 'project.store_symbol_address'                                    command_output_filtered = '\n'.join(list(filter(lambda x: symbol in x, command_output.split('\\n'))))                                    # Example output for readelf command:                                    #                                    # 573: 00000080   128 OBJECT  GLOBAL DEFAULT    1 symbol                                    result = re.search(r'.+: +(.+) +.+ +OBJECT +GLOBAL +.+ +.+ +{symbol_name}$'.format(symbol_name=symbol), command_output_filtered, flags=re.M)                                    if None != result:                                        symbol_address = result.group(1).strip()                                        # Save the symbol:address                                        project[symbol] = symbol_address                                # The symbol:address pairs are stored to the test_info.yml. The list of symbols to store can be deleted.                                del project['store_symbol_address']                            # Get the RTT block address u[sing arm-none-eabi-nm                            output = check_output(['arm-none-eabi-nm',  '-s', project['rtt_address_elf']])                            for line in output.decode().split('\n'):                                if ' _SEGGER_RTT' in line:                                    rtt_address = line.split(' ')[0]                                    project['rtt_address'] = rtt_address                        except:                            # An exception occurred when trying to get the RTT address from the elf file.                            # This can occur if the elf file was not created (likely because of a build failure)                            pass            # Write the results back to the yml file.            with open(yaml_file, 'wb') as f:                f.write(yaml.safe_dump(yml_dict, encoding='utf-8', allow_unicode=True))    print("Code Size Calculation")    code_sizes = []    cmd_out = []    idx = 0    print_idx = 0    for elf_file, main_objs, _, _ in sorted(g_project_list):        build_output_folder, _ = os.path.split(elf_file)        for main_obj in sorted(main_objs):            main_obj_path = str(main_obj)            # Maintain configured number of threads            while(threading.active_count() > GetOption('num_jobs')):                pass            cmd_out.append(0)            code_sizes.append(0)            thread = threading.Thread(target=get_code_size, args=(main_obj_path, cmd_out, code_sizes, idx))            thread.start()            idx = idx + 1        # Print output as threads finish        if len(cmd_out) > print_idx and cmd_out[print_idx] != 0:            if 0 == print_idx:                # Print Heading                print(cmd_out[0].splitlines()[0].decode() + " build name")            print(cmd_out[print_idx].splitlines()[1].decode())            print_idx = print_idx + 1    # Wait for all threads to complete    while(threading.active_count() > 1):        pass    while(print_idx < len(cmd_out)):        try:            print(cmd_out[print_idx].splitlines()[1].decode())        except:            print("Error - Missing build artifact")        print_idx = print_idx + 1    if(CONST_FUNCTION_SIZE):      sizes = {}      builds = []      for full_build, functions in code_sizes.items():        build = full_build.split('/')[-2].strip('build_').rstrip('_debug') + '_' + full_build.split('/')[-3]        builds.append(build)        for function, size in functions.items():          if function.split('.')[-1] not in sizes:            sizes[function.split('.')[-1]] = {}          sizes[function.split('.')[-1]][build] = size      for function, configs in sorted(sizes.items(), key=operator.itemgetter(0)):        print(function)        for config, size in sorted(configs.items(), key=operator.itemgetter(0)):          print('\t%s:\t\t%s'%(config, size))    # Check for elf output files    print(" ")    for elf_file, _, statement, build_config_name in g_project_list:        elf_output_string = "***   The build " + statement + " "        while len(elf_output_string) <= 80:            elf_output_string += " "        scons_build_marked_failure = any(build_config_name in e.node.name for e in build_failure_objects)        if scons_build_marked_failure and os.path.isfile(elf_file):            elf_output_string += "FAILED Post Build (srec_check.py likely)"        elif os.path.isfile(elf_file):            elf_output_string += "SUCCEEDED"        else:            elf_output_string += "FAILED"        print(elf_output_string)# Parse command line optionsAddOption('--build',        dest='global_build_dir',        type='string',        action='store',        metavar='MODULE',        help="Module or list of modules to build, for example --build=r_wdt or --build=\"r_adc r_ble r_crc\" must match a file or folder in 'projects' folder")AddOption('--cfg',        dest='build_config',        type='string',        nargs=1,        action='store',        help='Build configuration (leave off build_ and _debug: for example, r_wdt_pc_nmi')AddOption('--board',        dest='board',        type='string',        nargs=1,        action='store',        help='Board, for example --board=ra6m3_pk')AddOption('--project',        dest='project',        type='string',        nargs=1,        action='store',        help="Project <name> defined in XML file in 'projects' folder")AddOption('--compiler',        dest='compiler',        type='string',        nargs=1,        action='store',        help='Compiler, for example --compiler=gcc')AddOption('--use_gcov',        dest='use_gcov',        action='store_true',        default=False,        help='Add this option to enable code coverage using GCOV')AddOption('--fs',        dest='function_size',        action='store_true',        default=False,        help='Output the function sizes for all configurations')AddOption('--static_analyze',        dest='static_analyze',        default=None,        metavar='FIX_OR_EXPORT',        help="Add this option to enable clang-tidy for checking violations. 'export' is recommended. "        "'fix' applies fixes, but may cause code not to build.  Always commit before using --static_analyze=fix")AddOption('--only_libs',        dest='only_libs',        action='store_true',        default=False,        help='Only create libraries, no ELFs')AddOption('--declutter',        dest='declutter',        action='store_true',        default=False,        help='Hide full compiler/linker commands when building and suppress clang-tidy clutter')AddOption('--rtt_addr_in_yml',        dest='rtt_addr_in_yml',        action='store_true',        default=False,        help='Add RTT address in build yml, requires pending SConstruct on linker stage')AddOption('--skip_srec_check',        dest='skip_srec_check',        action='store_true',        default=False,        help='Add this option to skip srec checking after building')AddOption('--exclude_project',        dest='exclude_projects',        type='string',        action='append',        default=[],        help='Skip a project from being built')AddOption('-O', '--optimization_level',        dest='optimization_override',        type='string',        default=None,        help='Override the optimization level')# Set number of CPUs to enable parallel buildnum_cpus = multiprocessing.cpu_count()# Run with one more job than cores.#  - Though not entirely scientific, in my testing this seems to yield about a 5-10% speed improvement, more did not seem to be better though.SetOption('num_jobs', num_cpus+1)print("running with -j " + str(GetOption('num_jobs')))global_build_dir = GetOption('global_build_dir')if global_build_dir:    global_build_dir = os.path.relpath(global_build_dir)CONST_USE_GCOV = GetOption('use_gcov')static_analyze = GetOption('static_analyze')CONST_FUNCTION_SIZE = GetOption('function_size')CONST_ONLY_LIBS = GetOption('only_libs')CONST_DECLUTTER = GetOption('declutter')OPTIMIZATION_OVERRIDE = GetOption('optimization_override')# Will get this information from tools cfg file if presentif not GetOption('help'):    update_global_path()    # Build a specific project    projects_to_build = re.split(r",| ", global_build_dir)    if not global_build_dir:        projects_to_build = [CONST_PROJECT_XML_DIR]    print(projects_to_build)    # Create projects Object (gathers toolchains and asst. build info)    projects = project_data(CONST_COMMON_TOOLS_FILE)    for e in projects_to_build:        projects.add_project(e)    projects.build_projects()    # Create test info    for key in g_target_groups:        with open(os.path.join(key, 'test_info.yml'), 'w') as f:            f.write(yaml.dump(g_target_groups[key]))if not GetOption('clean') and not GetOption('help'):    atexit.register(exit_func)