import atexitimport copyimport hashlibimport itertoolsimport jsonimport multiprocessingimport ntpathimport operatorimport os, shutilimport platformimport reimport sysimport threadingimport xml.dom.minidomimport yamlimport pdb # Used for debugging. Use pdb.set_trace() to set a breakpointfrom lxml import etree # lxml preserves element order when parsingfrom subprocess import Popen, PIPE, callfrom subprocess import check_output, check_callfrom collections import defaultdict# FSP python librariessys.path.append('scripts/artifacts')from parse_objdump import parse_code_sizesys.path.append('scripts')from utility import find_project_xml_files# Common file names and locationsCONST_PROJECT_XML_DIR = 'projects'CONST_COMMON_PROJECT_FILE = 'test_files/shared/common.xml'CONST_COMMON_TZ_S_PROJECT_FILE = 'test_files/shared/common_tz_s.xml'CONST_COMMON_TZ_NS_PROJECT_FILE = 'test_files/shared/common_tz_ns.xml'CONST_COMMON_BOOT_PROJECT_FILE = 'test_files/shared/common_boot.xml'CONST_COMMON_BOOT_APP_PROJECT_FILE = 'test_files/shared/common_boot_app.xml'CONST_COMMON_AWS_PROJECT_FILE = 'test_files/shared/common_aws.xml'CONST_COMMON_PRIMARY_CORE_PROJECT_FILE = 'test_files/shared/common_primary_core.xml'CONST_COMMON_SECONDARY_CORE_PROJECT_FILE = 'test_files/shared/common_secondary_core.xml'CONST_COMMON_PRIMARY_CORE_TZ_S_PROJECT_FILE = 'test_files/shared/common_primary_core_tz_s.xml'CONST_COMMON_PRIMARY_CORE_TZ_NS_PROJECT_FILE = 'test_files/shared/common_primary_core_tz_ns.xml'CONST_COMMON_SECONDARY_CORE_TZ_S_PROJECT_FILE = 'test_files/shared/common_secondary_core_tz_s.xml'CONST_COMMON_SECONDARY_CORE_TZ_NS_PROJECT_FILE = 'test_files/shared/common_secondary_core_tz_ns.xml'CONST_COMMON_BOOT_MULTI_IMAGES_PROJECT_FILE = 'test_files/shared/common_boot_multi_images.xml'CONST_COMMON_BOOT_APP_MULTI_IMAGES_PROJECT_FILE = 'test_files/shared/common_boot_app_multi_images.xml'CONST_COMMON_TOOLS_FILE = 'test_files/shared/tools.yml'CONST_TOOLS_CFG_FILE_NAME = 'test_files/shared/tools_cfg.yml'CONST_MCU_CFG_FILE = 'test_files/shared/mcu_cfg.yml'CONST_COMMON_BOOT_MULTI_CORE_PROJECT_FILE = 'test_files/shared/common_boot_multi_core.xml'CONST_COMMON_BOOT_APP_PRIMARY_CORE_PROJECT_FILE = 'test_files/shared/common_boot_app_primary_core.xml'CONST_COMMON_BOOT_APP_SECONDARY_CORE_PROJECT_FILE = 'test_files/shared/common_boot_app_secondary_core.xml'# Define the core and default optimization level build(s) for each part.with open(CONST_MCU_CFG_FILE, 'r') as f:    CONST_MCU_DICT = yaml.load(f, Loader=yaml.Loader)# Lookups for the features of the different cores.CONST_CORE_FPU_DICT = { '23':None,                        '33':'5',                        '4' :'4',                        '85':'5' }CONST_CORE_CMSE_DICT = { '23':False,                         '33':True,                         '4' :False,                         '85':True }CONST_CORE_ARM_ARCH_DICT = { '23':'__ARM_ARCH_8M_BASE__',                             '33':'__ARM_ARCH_8M_MAIN__',                             '4' :'__ARM_ARCH_7EM__',                             '85':'__ARM_ARCH_8_1M_MAIN__' }CONST_CORE_ARM_ARCH_FLAGS_DICT = { '23':'',                                   '33':'',                                   '4' :'',                                   '85' :''}CONST_CORE_ARM_GCC_85_HACKS_DICT = { 'primary_core' : '33' }CONST_EXTRA_WARNINGS = TrueCONST_GCOV_MIN_HEAP_SIZE = 0x1000CONST_GCOV_MIN_STACK_SIZE = 0xD00# Global Variablesg_dependent_projects = []g_project_list = []g_target_groups = {} # Information used to generate test_info.ymlg_scons_cache_dir = ''# Global cache of source files that are found for buildingg_dir_to_file_lookup = {}def create_common_env(project, toolchain, board, mcu, optimization_level, third_party=False):    """ Helper function to create common env used for the current project. USed by both build_project_helper and build_configuration classes. """    env = create_env()    configure_project_environment(env, project)    configure_build_environment(env, optimization_level, toolchain, project, board.upper())    configure_tool_environment(env, toolchain, mcu, project, third_party)    configure_build_rules(env)    return envclass project_data():    """ Define project data class to store all variables related to build. """    def __init__(self, tools_def_yml):        self.toolchains = []        self.projects = {} # Includes build variants        self.build_stack = [] # The order to build the projects, including secure project dependencies        self.project_files = [] # List of project files to build        # Get toolchain configurations        self._parse_toolchains(tools_def_yml, self.toolchains)    def _parse_toolchains(self, file, toolchains):        with open(file, 'r') as f:            yml_toolchains = yaml.load(f, Loader=yaml.Loader)        self.compiler_list = yml_toolchains.keys()        for key in self.compiler_list:            tc = toolchain(yml_toolchains[key])            toolchains.append(tc)    def _add_project(self, filename, xml_root):        if xml_root.tag == "projects":            for new_root in xml_root.findall("project"):                self._add_project(filename, new_root)            return        type = xml_root.find("type")        # Add projects according to type        #  - Default to 'flat' project type        if type is None or type.text == 'flat':            type_str='flat'            new_proj = project_common(filename, xml_root)        elif type.text == 'tz_s':            type_str='tz_s'            new_proj = project_tz_secure(filename, xml_root)        elif type.text == 'tz_s_only':            type_str='tz_s_only'            new_proj = project_tz_secure(filename, xml_root)            new_proj.type = type_str        elif type.text == 'tz_ns':            type_str='tz_ns'            new_proj = project_tz_nonsecure(filename, xml_root)        elif type.text == 'boot':            type_str='boot'            new_proj = project_boot(filename, xml_root)        elif type.text == 'boot_app':            type_str='boot_app'            new_proj = project_boot_app(filename, xml_root)        elif type.text == 'aws_qual':            type_str='aws_qual'            new_proj = project_aws(filename, xml_root)        elif type.text == 'secondary_core':            type_str='secondary_core'            new_proj = project_secondary_core(filename, xml_root)        elif type.text == 'primary_core':            type_str='primary_core'            new_proj = project_primary_core(filename, xml_root)        elif type.text == 'secondary_core_tz_ns':            type_str='secondary_core_tz_ns'            new_proj = project_secondary_core_tz_ns(filename, xml_root)        elif type.text == 'secondary_core_tz_s':            type_str='secondary_core_tz_s'            new_proj = project_secondary_core_tz_s(filename, xml_root)        elif type.text == 'primary_core_tz_ns':            type_str='primary_core_tz_ns'            new_proj = project_primary_core_tz_ns(filename, xml_root)        elif type.text == 'primary_core_tz_s':            type_str='primary_core_tz_s'            new_proj = project_primary_core_tz_s(filename, xml_root)        elif type.text == 'boot_multi_images':            type_str='boot_multi_images'            new_proj = project_boot_multi_images(filename, xml_root)        elif type.text == 'boot_app_multi_images':            type_str='boot_app_multi_images'            new_proj = project_boot_app_multi_images(filename, xml_root)        elif type.text == 'boot_multi_core':            type_str='boot_multi_core'            new_proj = project_boot_multi_core(filename, xml_root)        elif type.text == 'boot_app_primary_core':            type_str='boot_app_primary_core'            new_proj = project_boot_app_primary_core(filename, xml_root)        elif type.text == 'boot_app_secondary_core':            type_str='boot_app_secondary_core'            new_proj = project_boot_app_secondary_core(filename, xml_root)        else:            # Unknown build type            assert()        # Get unique but deterministic name for this build, so we can reference it later        hash_gen = hashlib.sha256()        xml_items = [str(e.text) if e is not None else '' for e in xml_root.iter()]        str_cat = ''.join(xml_items).encode()        hash_gen.update(str_cat)        build_key = new_proj.module_name+"_"+type_str+"_"+str(hash_gen.hexdigest())        # Add project and dependencies if we haven't already        # Use stack to keep track of required build order.        if build_key not in self.build_stack:            self.projects[build_key] = new_proj            self.build_stack.append(build_key)            for p in new_proj.dependencies:                g_dependent_projects.append(p)                self.add_project(p)    def add_project(self, project):        """ @project can be a directory or project name. e.g. a value of 'projects' will build all project xmls contained in the 'projects' folder """        # Find build xml, reduce to xmls that haven't been processed yet        project_files = find_project_xml_files(project)        project_files = [e for e in project_files if e.endswith('.xml')]        project_files = [e for e in project_files if not any(filter(lambda x: e.endswith(f'{x}.xml'), GetOption('exclude_projects')))]        project_files = [e for e in project_files if e not in self.project_files]        # Mark files processed early to short-circuit recursion        self.project_files = self.project_files + project_files        # Add all projects defined in the xml        for file in project_files:            tree = etree.parse(file)            root = tree.getroot()            self._add_project(file, root)    def _filter_boards(self, project, arg_board):        """        Filter board list based on project definition and command line argument        """        arg_board_list = arg_board.replace("\"", "").rstrip(" ").split(" ") if arg_board else []        boards = []        for e in project.boards:            if (0 == len(arg_board_list)) or any(board_token in e for board_token in arg_board_list):                boards.append(e)        return boards    def _filter_toolchains(self, project, arg_toolchain):        """        Filter toolchain list based on project definition and command line argument        """        toolchains = [e for e in self.toolchains if not arg_toolchain or e.name == arg_toolchain]        toolchains = [e for e in toolchains if e.name not in project.skip_compiler]        return toolchains    def _find_source_files(self, search_directories):        """        Helper to find source files            Search directories : A list of files and/or directories to look for source files        NOTE: This function could really use some cleanup, but moving it out of a monlithic function is good enough for now.        """        files_array = set()        for search_dir in search_directories:            filepaths = []            to_cache_libs = set()            key = (search_dir, self.current_mcu, frozenset(self.project.exclude_dirs), self.project.build_module_source_only, self.board)            if key in g_dir_to_file_lookup:                filtered_paths = g_dir_to_file_lookup[key]["source_files"]                files_array.update(filtered_paths)                filtered_libs = g_dir_to_file_lookup[key]["libs"]                if len(filtered_libs) > 0:                    self.list_of_libs.update()                continue            else:                filtered_paths = set()                if os.path.isfile(search_dir):                    temp_path, temp_name = os.path.split(search_dir)                    filepaths.append((temp_path, [temp_name]))                else:                    for (dirpath, _, filenames) in os.walk(search_dir):                        filepaths.append((dirpath, filenames))            for (dirpath, filenames) in filepaths:                rel_path = os.path.relpath(dirpath, search_dir)                if '!' in rel_path:                    continue                for filename in filenames:                    filepath = os.path.normpath(os.path.join(dirpath, filename))                    # Skip files that are in an exclude path                    if any(exclude in filepath for exclude in self.project.exclude_dirs):                        continue                    is_source = filename.endswith('.c') or filename.endswith('cpp') or filename.endswith('cc') or filename.endswith('.s') or filename.endswith('.S')                    is_template = filename.endswith('.c.template') and os.path.relpath(filepath).startswith('ra/fsp/')                    if not (is_source or is_template or filename.endswith('.a')):                        continue                    if filename.endswith('.a'):                        to_cache_libs.add(filepath)                        self.list_of_libs.add(filepath)                    # Add file to build if it's a source file or template AND we're building an example project                    if ((is_template and self.project.build_module_source_only) or is_source):                        filtered_paths.add(filepath)                        files_array.add(filepath)            if key not in g_dir_to_file_lookup:                g_dir_to_file_lookup[key] = {"source_files": filtered_paths, "libs": to_cache_libs}        return list(set(files_array)) # Remove duplicates for this group    def _substitute_environment_variables(self, environment, file_list):        """ Helper to substitute environment variables in given project paths. """        sub_list = environment.subst(file_list)        # AC6 needs the substituted 'SEGGER_RTT_Syscalls_AC6.c replaced with 'SEGGER_RTT_Syscalls_KEIL.c' because that is what SEGGER calls it        if self.toolchain.name == "ac6" and ("test_files/src/RTT/SEGGER_RTT_Syscalls_AC6.c" in sub_list):            sub_list = list(map(lambda l: l.replace('test_files/src/RTT/SEGGER_RTT_Syscalls_AC6.c', 'test_files/src/RTT/SEGGER_RTT_Syscalls_KEIL.c'), sub_list))        return sub_list    def _initialize_project(self, project, toolchain, board, mcu, o_level):        """        Initialize a specific project. Including capturing self variables and building lists of files for building        """        self.project = project        self.toolchain = toolchain        self.board = board        self.current_mcu = mcu        self.o_level = o_level        self.project_name = self.project.module_name        if self.project.name:            self.project_name += '_' + self.project.name        ######################################################################        ####                     Create list of files                     ####        ######################################################################        # create env for building common source files        self.common_env = create_common_env(project, toolchain, board, mcu, self.o_level)        # Order of operations is important for the following block        self.list_of_common_files           = self._find_source_files(self._substitute_environment_variables(self.common_env, project.common_dirs))        self.list_of_third_party_test_files = self._find_source_files(self._substitute_environment_variables(self.common_env, project.third_party_test_dirs))        self.list_of_test_files             = self._find_source_files(self._substitute_environment_variables(self.common_env, project.test_dirs))        self.list_of_main_files             = self._find_source_files(self._substitute_environment_variables(self.common_env, project.main_dirs))        # remove source files that are in multiple src groups        self.list_of_no_instrument_files      = project.no_instrument_files        self.list_of_third_party_test_files   = list(filter(lambda x: x not in self.list_of_no_instrument_files, self.list_of_third_party_test_files))        self.list_of_main_files   = list(filter(lambda x: x not in self.list_of_no_instrument_files and x not in self.list_of_third_party_test_files, self.list_of_main_files))        self.list_of_test_files   = list(filter(lambda x: x not in self.list_of_no_instrument_files and x not in self.list_of_main_files and x not in self.list_of_third_party_test_files, self.list_of_test_files))        self.list_of_common_files = list(filter(lambda x: x not in self.list_of_no_instrument_files and x not in self.list_of_test_files and x not in self.list_of_main_files and x not in self.list_of_third_party_test_files, self.list_of_common_files))        # Check to see if this is a C or C++ build. If it's C++ we need to alter linker flags for some toolchains (eg: AC6)        self.cpp_build = False        for f in self.list_of_no_instrument_files + self.list_of_third_party_test_files + self.list_of_main_files + self.list_of_test_files + self.list_of_common_files:            if (os.path.splitext(f)[1]) in ['.cc', '.cpp', '.c++', '.cp', '.cxx']:                self.cpp_build = True        # For AC6, standard lib is required to build C++ projects. microlib does not support C++        if (toolchain.name == "ac6") and (self.cpp_build == True):            # For AC6 we need to add a macro that indicates that standardlib is used instead of microlib for C++ projects            project.common_macros['__ARMCC_USING_STANDARDLIB'] = '1'        # Ensure no module files are in the test files group        assert( not any(project.module_name+'.c' in e for e in self.list_of_test_files)) # Module files should not be listed in '<test_dir>' section of project XML    def _print_project_debug_info(self, project, toolchains, boards):        """        Prints project, toolchain, and board information to the console        """        dbg_info_toolchains = [e.name for e in toolchains]        dbg_info_boards = ["Source Only"] if not boards else boards        dbg_info_name = project.name if project.name else 'debug'        dbg_info_num_builds = len(dbg_info_toolchains) * len(dbg_info_boards)        print("\r\n" + 125*"=" + "\r\n" +\                f"Project: {project.module_name} {project.type} {dbg_info_name} - {dbg_info_num_builds} builds \r\n" +\                f" - {dbg_info_toolchains}\r\n" +\                f" - {dbg_info_boards} \r\n" +\                125*"=")    def build_projects(self):        """        Iterates the predetermines lists of build_stack and projects to build applicable project permutations        """        arg_toolchain = GetOption('compiler')        arg_project = GetOption('project')        arg_board = GetOption('board')        # Build all projects that have already been added        # NOTE: Stack used to manage order        while self.build_stack:            build_key = self.build_stack.pop()            project = self.projects[build_key]            if arg_project and arg_project != project.name and project.module_name not in g_dependent_projects:                continue            # Skip processing for non-libraries if --only_libs is specified            if CONST_ONLY_LIBS and not (project.create_lib or project.build_module_source_only):                continue            # Filter boards, toolchains            boards = self._filter_boards(project, arg_board)            if not boards:                continue            toolchains = self._filter_toolchains(project, arg_toolchain)            # Permutate toolchains, boards, optimization levels, and main macro configurations            self._print_project_debug_info(project, toolchains, boards)            for toolchain in toolchains:                # Don't build TrustZone projects with gcov                if 'tz' in project.type and CONST_USE_GCOV and toolchain.name == 'gcc':                    continue                for board in boards:                    mcu = board.split('_')[0].lower()                    for o_level in CONST_MCU_DICT[mcu]['o_levels']:                        self._initialize_project(project, toolchain, board, mcu, o_level)                        for key in project.main_macro_configurations:                            self.build_config_name = self.project_name + '_' + str(key)                            self._do_build(key)    def _do_build(self, key):        """ The overarching function that performs the building for a given project, including determining project source files from project XML and building individual project configurations. """        ######################################################################        ####        Create executable for each macro configuration        ####        ######################################################################        key_info = build_configuration(self.common_env, self.list_of_common_files, self.list_of_third_party_test_files, self.list_of_test_files, self.list_of_main_files, self.list_of_no_instrument_files,                                       self.project, self.toolchain, key, self.build_config_name, self.board, self.current_mcu, self.o_level)        if GetOption('build_config') and GetOption('build_config') != self.build_config_name and self.project.module_name not in g_dependent_projects:            return        if not os.path.exists(key_info.output_dir):            os.makedirs(key_info.output_dir)        # Skip builds not in the global build directory        if global_build_dir:            if 'build' in global_build_dir and global_build_dir not in os.path.relpath(key_info.output_dir):                return        ######################################################################        ####             Add dependencies to build description            ####        ######################################################################        for dependency in self.project.dependencies:            key_info._add_dependency(dependency)        ######################################################################        ####           Create and update respective environments          ####        ######################################################################        key_info._create_environments(self.o_level)        # Don't build tests for TX_ENABLE_IAR_LIBRARY_SUPPORT for GCC or AC6        if 'TX_ENABLE_IAR_LIBRARY_SUPPORT' in key_info.test_env['CPPDEFINES'] and 'iar' != self.toolchain.name:            return        ######################################################################        ####            Configure Clang-Tidy - if applicable              ####        ######################################################################        if static_analyze is not None and self.toolchain.clang_tidy_com and not self.project.ignore_warnings:            key_info._configure_clang_tidy(self.current_mcu)        ######################################################################        ####                Create lists of objects to build              ####        ######################################################################        if self.project.create_lib:            key_info._configure_library()        elif not CONST_ONLY_LIBS:            key_info.main_objs   = key_info.main_env.Object(list(map(lambda x: os.path.join(key_info.output_dir, x), key_info.list_of_main_files)))        # If we are building only the module source or libraries, skip building test/common files and linking        if (self.project.build_module_source_only) or (CONST_ONLY_LIBS == True) or (self.project.create_lib):            key_info.main_env.VariantDir(key_info.output_dir, '.', duplicate = 0)            return        # Add main, no instrument, common, test, and third party files to object list        key_info._create_object_list(key_info.main_objs)        elf_output_key = str(self.build_config_name + ":debug:" + self.board + ":" + self.toolchain.name + ":")        g_project_list.append((key_info.output_elf_file, key_info.main_objs, elf_output_key, self.build_config_name))        ######################################################################        ####            Configure linker and executable environment       ####        ######################################################################        target_file = key_info._configure_executable_environment(self.o_level, self.cpp_build)        ######################################################################        ####        Configure post-build step to generate .srec           ####        ######################################################################        key_info._configure_post_build()        # To reduce cache size, don't cache .elf files        NoCache(key_info.output_elf_file)        AlwaysBuild(key_info.output_elf_file)        ######################################################################        ####               Configure secure-only project                  ####        ######################################################################        # In most cases the secure-only project should be skipped.        # Projects with type = tz_s_only are a special case where the unity test framework executes in the secure project.        # These project types are not skipped here.        if ('tz_s' not in self.project.type) or ('tz_s_only' == self.project.type):            key_info._configure_secure_project()        ######################################################################        ####                     Configure coverage                       ####        ######################################################################        use_gcov = CONST_USE_GCOV and self.toolchain.name == 'gcc'        if use_gcov:            key_info._configure_coverage()        ######################################################################        ####     Add implicit dependencies to executable environment      ####        ######################################################################        key_info._add_implicit_dependencies()        ######################################################################        ####                 Perform build of executable                  ####        ######################################################################        key_info.exe_env.Program(target = target_file, source = key_info.object_list)        ######################################################################        ####             Sign bootloader application images               ####        ######################################################################        if 'boot_app' in self.project.type:            key_info._sign_bootloader_application_image()class build_configuration():    """ Define a build configuration object to handle the actual build objects and outputs for a specific build. """    def __init__(self, common_env, common_files, third_party_test_files, test_files, main_files, no_instrument_files,                 project, toolchain, key, build_config_name, board, current_mcu, o_level):        self.toolchain = toolchain        self.project = project        self.build_config_name = build_config_name        self.board = board        self.current_mcu = current_mcu        self.o_level = o_level        self.common_env = common_env        self.list_of_libs = []        self.list_of_common_files = common_files        self.list_of_third_party_test_files = third_party_test_files        self.list_of_test_files = test_files        self.list_of_main_files = main_files        self.list_of_no_instrument_files = no_instrument_files        self.key = key        self.build_info = {}        self.build_info['dependencies'] = []        self.main_env = None        self.test_env = None        self.no_instrument_env = None        self.third_party_test_env = None        self.exe_env = None        self.object_list = []        self.main_objs = []        self.secure_import_lib = ''        self.secure_import_elf = ''        self.output_file = ''        self.output_dir = ''        self.output_file_path = ''        self.output_elf_file = ''        self.output_srec_file = ''        self._initialize_output_vars()        if 'primary' in self.project.type or 'boot_multi_core' == self.project.type:            self.build_info['core'] = 0        elif 'secondary' in self.project.type:            self.build_info['core'] = 1    def _initialize_output_vars(self):        """ Helper to initialize the various output variables with project and configuration specific values, includes .srec and .elf files. """        self.output_file = 'build_' + self.build_config_name + '_debug'        self.output_dir = os.path.join('build', self.project.module_name, self.board, self.toolchain.name, self.output_file)        self.output_file_path = os.path.join(self.output_dir, self.output_file)        self.output_elf_file = self.output_file_path + '.elf'    def _add_dependency(self, dependency):        """ Helper to add a given dependency to the project configuration. """        # Certain project info gets saved to file, except for Trust Zone secure projects        if 'tz_ns' in self.project.type:            # Find all secure object files for this build            self.secure_import_lib = 'build/' + dependency + '/' + self.board + '/' + self.toolchain.name + '/build_' + dependency + '_' + self.key + '_debug' + '/build_' + dependency + '_' + self.key + '_debug.elf.o'            self.secure_import_elf = self.secure_import_lib[:-len('.o')]            # See if this is AC6 and we need to include the SREC file instead            secure_srec = self.secure_import_lib[:-len('.elf.o')] + '.srec'            self.build_info['dependencies'].append(secure_srec)        elif 'FSP_BOOTLOADER_PROJECT' in self.project.test_macros:            # Don't add dependency to build_info if it is a library            if any(dependency in lib for lib in self.project.libraries):                return            # Only typical build supported for boot apps            boot_app = 'build/' + dependency + '/' + self.board + '/' + self.toolchain.name + '/build_' + dependency + '_typical_debug' + '/build_' + dependency + '_typical_debug.bin'            boot_app_signed = boot_app.replace('.bin', '.signed.srec')            self.build_info['dependencies'].append(boot_app_signed)            if 'FSP_BOOTLOADER_DOWNLOADER' not in self.project.test_macros:                secondary_app = 'build/' + dependency + '/' + self.board + '/' + self.toolchain.name + '/build_' + dependency + '_secondary_debug' + '/build_' + dependency + '_secondary_debug.bin'                secondary_app_signed = secondary_app.replace('.bin', '.signed.srec')                self.build_info['dependencies'].append(secondary_app_signed)                self.build_info['rtt_address_elf'] = secondary_app.replace('.bin', '.elf')            else:                self.build_info['rtt_address_elf'] = boot_app.replace('.bin', '.elf')        elif 'core' in self.project.type:            srec = 'build/' + dependency + '/' + self.board + '/' + self.toolchain.name + '/build_' + dependency + '_' + self.key + '_debug' + '/build_' + dependency + '_' + self.key + '_debug.srec'            self.build_info['dependencies'].append(srec)    def _add_implicit_dependencies(self):        """        Helper to find and add implicit dependencies to the project configuration.        Some projects define include files via the pre-processor. Scons is not good at        finding these, so we add them explicitly here.        NOTE: Currently this makes all build files dependent on the implicit files,                which could be improved later if needed.        """        implicit_dependencies = []        for file in self.project.implicit_dependencies:            for path in self.project.includes:                full_path = os.path.join(path,file)                if os.path.exists(full_path):                    implicit_dependencies.append(full_path)                    print('LOG: Implicit dependency: {}'.format(full_path))        self.exe_env.Depends(self.object_list, implicit_dependencies)        # Because bsp_override_reg.h is included via a macro, scons will not automatically detect that it is a dependency.        bsp_override_reg_headers = [os.path.join(d[0], 'bsp_override_reg.h') for d in os.walk('ra/fsp/src/bsp/mcu/') if 'bsp_override_reg.h' in d[2]]        self.exe_env.Depends(self.object_list, bsp_override_reg_headers)    def _create_environments(self, o_level):        """ Helper to create the various build environments, except 'common_env' - that is done at the project level. """        # create env for building main source files        self.main_env = create_common_env(self.project, self.toolchain, self.board, self.current_mcu, o_level)        self.main_env['CPPDEFINES'].update(self.project.test_macros)        self.main_env['CPPDEFINES'].update(self.project.main_macro_configurations[self.key])        self.main_env['COMMON_FLAGS'] = copy.deepcopy(self.main_env['COMMON_FLAGS']) + self.toolchain.extra_flags        # create env for building test test files        test_file_optimization_level = 'typical' if o_level == 'size' else o_level        self.test_env = create_common_env(self.project, self.toolchain, self.board, self.current_mcu, test_file_optimization_level)        self.test_env['CPPDEFINES'].update(self.project.test_macros)        self.test_env['CPPDEFINES'].update(self.project.main_macro_configurations[self.key])        # No optimize environment - no coverage        self.no_instrument_env = create_common_env(self.project, self.toolchain, self.board, self.current_mcu, o_level)        self.no_instrument_env['CPPDEFINES'].update(self.project.test_macros)        self.no_instrument_env['CPPDEFINES'].update(self.project.main_macro_configurations[self.key])        # create env for building third party source files        self.third_party_test_env = create_common_env(self.project, self.toolchain, self.board, self.current_mcu, o_level, third_party=True)        self.third_party_test_env['CPPDEFINES'].update(self.project.test_macros)        self.third_party_test_env['CPPDEFINES'].update(self.project.main_macro_configurations[self.key])    def _configure_clang_tidy(self, mcu):        """ Helper to configure clang-tidy and add to appropriate environments """        # The following loop is a hack and likely can be removed when clang-tidy is updated to version 12 or greater        # NOTE: When this is removed, we'll need to add '--assume-filename' to the clang command for it to see the        # 'template' file as a 'c' file.        for file in [e for e in self.list_of_main_files if not e.endswith('c') or e.endswith('cpp')  or e.endswith('cc')]:            # Move and rename template file            temp_file = file.replace('.c.template', '.c')            temp_file = os.path.join(self.output_dir, ntpath.basename(temp_file))            shutil.copyfile(file, temp_file)            # Replace template file with temp-file in build command            self.list_of_main_files.remove(file)            self.list_of_main_files.append(temp_file)        # Add Clang Tidy to build command        clang_tidy_com = self.toolchain.clang_tidy_com        if CONST_CORE_CMSE_DICT[self.project.mcu_dict[mcu]]:            if 'tz_s' in self.project.type:                clang_tidy_com += " -D__ARM_FEATURE_CMSE=3"        self.main_env["CCCOM"] = clang_tidy_com + os.linesep + self.main_env["CCCOM"]        self.test_env["CCCOM"] = clang_tidy_com + os.linesep + self.test_env["CCCOM"]        self.no_instrument_env["CCCOM"] = clang_tidy_com + os.linesep + self.no_instrument_env["CCCOM"]    def _configure_library(self):        """ Helper to configure and build a library *.a archive. """        # If we need to create a library for this module then we need to create the *.a file and then use        # it in final linked elf instead of object files for main_dirs        # Still need to create object files for the library        lib_objs = self.main_env.Object(list(map(lambda x: os.path.join(self.output_dir, x), self.list_of_main_files)))        lib_objs.sort()        # Build Library        output_lib_file = os.path.join(self.output_dir, 'lib' + self.project.module_name + '.a')        NoCache(output_lib_file)        AlwaysBuild(output_lib_file)        print("Building lib: " + output_lib_file)        main_libs = self.main_env.StaticLibrary(output_lib_file, lib_objs)        # Add newly created library to list of libs to use when creating the ELF        self.list_of_libs.append(str(main_libs[0]))    def _create_object_list(self, main_objs):        """ Helper to create the lists of objects needed to build based on file lists. """        # FIX: Deduplicate file lists by normalized absolute path before creating objects.        # This prevents SCons "Two environments with different actions for same target" error        # when a source file (e.g. system.c from BSP) appears in multiple source groups.        _assigned = set()        def _dedup(file_list):            result = []            for f in file_list:                key = os.path.normcase(os.path.abspath(f))                if key not in _assigned:                    _assigned.add(key)                    result.append(f)            return result        deduped_no_instrument    = _dedup(self.list_of_no_instrument_files)        deduped_common           = _dedup(self.list_of_common_files)        deduped_test             = _dedup(self.list_of_test_files)        deduped_third_party_test = _dedup(self.list_of_third_party_test_files)        # object files to build        no_instrument_objs    = self.no_instrument_env.Object(list(map(lambda x: os.path.join(self.output_dir, x), deduped_no_instrument)))        common_objs           = self.common_env.Object(list(map(lambda x: os.path.join(self.output_dir, x), deduped_common)))        test_objs             = self.test_env.Object(list(map(lambda x: os.path.join(self.output_dir, x), deduped_test)))        third_party_test_objs = self.third_party_test_env.Object(list(map(lambda x: os.path.join(self.output_dir, x), deduped_third_party_test)))        self.object_list = (common_objs + test_objs + main_objs + third_party_test_objs + no_instrument_objs)        # sort list of input files to make output consistent        self.object_list.sort()    def _configure_executable_environment(self, o_level, cpp_build):        """ Helper to configure the overall executable environment responsible for generating the .elf. """        # if objects are passed to linker as arguments than the command will be too long and will fail        # to solve this problem, objects must be passed in using a file        link_file = self.output_dir + '/' + self.output_file + '.elf.in'        cmd = []        if not os.path.exists(self.output_dir):            os.makedirs(self.output_dir)        with open(link_file, 'w') as f:            for object in self.object_list:                cmd += str(object) + ' '            cmd = ''.join(cmd).replace('\\', '/')            f.write(cmd)        lib_names = list(map(lambda x: os.path.basename(x).strip('lib').split('.')[0], self.list_of_libs))        lib_paths = list(map(lambda x: os.path.dirname(x), self.list_of_libs))        # Create environment for linking all the objects together        self.exe_env = create_common_env(self.project, self.toolchain, self.board, self.current_mcu, optimization_level=o_level)        # For AC6, standard lib is required to build C++ projects        if self.toolchain.name == "ac6" and cpp_build:            self.exe_env["LINKFLAGS"].remove('--library_type=microlib')        self.exe_env.VariantDir(self.output_dir, '.', duplicate = 0)        target_file = os.path.join(self.output_dir, self.output_file)        # Remove existing binaries so old artifacts are not tested if the build was not successful        if os.path.exists(self.output_elf_file):            os.remove(self.output_elf_file)        if os.path.exists(self.output_elf_file + '.o'):            os.remove(self.output_elf_file + '.o')        # Add all libraries that were found        self.exe_env['LIBS'] += lib_names        self.exe_env['LIBPATH'] += lib_paths        self.exe_env["LINKFILE"] = link_file        if self.project.secondary_linker_includes and 'secondary' in self.build_config_name:            self.exe_env["LIBINCPATH"] = copy.deepcopy(self.project.secondary_linker_includes)        print("Building elf:" + self.output_elf_file)        self.exe_env['PROJECT_PATH'] = self.output_file_path        return target_file    def _configure_post_build(self):        """ Helper to configure post build steps. Like generating the .srec and executing srec_check.py. """        # For J-Link, program the srec instead of the .elf file        # Change output file name to 'srec' in build metadata file        self.output_srec_file = self.output_elf_file[:-len('.elf')] + '.srec'        # Write YML file that has project details        if 'ac6' == self.toolchain.name:            # Add elf -> srec builder to scons construction environment            self.exe_env.Command(self.output_srec_file, self.output_elf_file, 'fromelf --m32combined --output=${TARGET} ${SOURCE}')            self.build_info['application'] = self.output_srec_file        else:            self.build_info['application'] = self.output_srec_file            # Add elf -> srec builder to scons construction environment            self.exe_env.Command(self.output_srec_file, self.output_elf_file, 'arm-none-eabi-objcopy ${SOURCE} ${TARGET} -O srec')        if 'rtt_address_elf' not in self.build_info:            self.build_info['rtt_address_elf'] = self.output_elf_file        ######################################################################        ####        Configure post-build SREC check after linking         ####        ######################################################################        if not GetOption('skip_srec_check'):            if len(self.project.srec_check) > 0:                srec_args = ' '.join(map(lambda srec_action: '-' + srec_action[0] + ' ' + srec_action[1], self.project.srec_check))            else:                srec_args = ''            if 'tz_s' in self.project.type:                srec_args += ' -t ' + 'tz_s'            elif 'tz_ns' in self.project.type:                srec_args += ' -t ' + 'tz_ns'            self.exe_env.Command(None, self.output_srec_file, 'python3 scripts/srec_check/srec_check.py ' + srec_args + ' ${MCU} ${SOURCE}')    def _configure_secure_project(self):        """ Helper to configure secure only project and update test_info. """        with open(self.output_file_path + '.yml', 'w') as f:            f.write(yaml.dump(self.build_info))        # Generate test info that is used by fsp_test_parallel.py during testing.        test_info = self.build_info        test_info['name'] = self.project.name        test_info['board_id'] = self.project.target_group['board_id']        # Check if we need to init the project with some info from project XML        test_info.update(eval(self.project.test_info_init))        # Determine the output directory of "test_info.yml"        test_info_dir = os.path.join('build', self.project.module_name, self.board, self.toolchain.name)        # If the file does not exist, create an entry for storing data for this file.        if not test_info_dir in g_target_groups.keys():            g_target_groups[test_info_dir] = {}        # If the target group does not exist, create an entry for storing this target group.        if not self.project.target_group['name'] in g_target_groups[test_info_dir].keys():            g_target_groups[test_info_dir][self.project.target_group['name']] = {}        # If the build config does not exist, create an entry for storing this build config.        if not self.key in g_target_groups[test_info_dir][self.project.target_group['name']].keys():            g_target_groups[test_info_dir][self.project.target_group['name']][self.key] = {}            g_target_groups[test_info_dir][self.project.target_group['name']][self.key]['projects'] = []        # Store the test info for this project.        g_target_groups[test_info_dir][self.project.target_group['name']][self.key]['projects'].append(test_info)        # Add secure project to main object list        self.exe_env['CMSE_IMPORT_LIB'] = self.secure_import_lib        if 'TX_ENABLE_IAR_LIBRARY_SUPPORT' in self.test_env['CPPDEFINES'] and 'iar' == self.toolchain.name:            self.exe_env['LINKFLAGS'] += self.toolchain.iar_lib_link_flags        if (self.secure_import_elf):            # Ensure the secure project is built before the non-secure project            self.object_list.append(self.secure_import_elf)    def _configure_coverage(self):        """ Helper to configure arguments and environments for coverage builds for coverage testing. """        # Don't cache FUT for coverage. This is to try and force        # creation of gcov gcno files.        NoCache(self.main_objs)        self.main_env.MergeFlags({            "CXX_FLAGS": ['-fprofile-arcs', '-ftest-coverage']        })        self.main_env['OPTIMIZATION'] = self.toolchain.optimization_levels['none']        self.exe_env.MergeFlags({            "LINKFLAGS": ['-fprofile-arcs']        })        self.test_env["CPPDEFINES"]['TEST_FSP_USE_GCOV'] = '1'        # RTT code needs this        self.third_party_test_env["CPPDEFINES"]['TEST_FSP_USE_GCOV'] = '1'        # Start off with default minimums        heap_size = hex(CONST_GCOV_MIN_HEAP_SIZE)        stack_size = hex(CONST_GCOV_MIN_STACK_SIZE)        # If heap or stack size is defined then it needs to be >= the minimum        if 'BSP_CFG_HEAP_BYTES' in self.test_env["CPPDEFINES"]:            if int(self.test_env["CPPDEFINES"]['BSP_CFG_HEAP_BYTES'], 0) > CONST_GCOV_MIN_HEAP_SIZE:                heap_size = self.test_env["CPPDEFINES"]['BSP_CFG_HEAP_BYTES']        self.test_env["CPPDEFINES"]['BSP_CFG_HEAP_BYTES'] = heap_size        self.no_instrument_env["CPPDEFINES"]["BSP_CFG_HEAP_BYTES"] = heap_size        if 'BSP_CFG_STACK_MAIN_BYTES' in self.test_env["CPPDEFINES"]:            if int(self.test_env["CPPDEFINES"]['BSP_CFG_STACK_MAIN_BYTES'], 0) > CONST_GCOV_MIN_STACK_SIZE:                stack_size = self.test_env["CPPDEFINES"]['BSP_CFG_STACK_MAIN_BYTES']        if 'DEMO_STACK_SIZE' in self.test_env["CPPDEFINES"]:            if self.test_env["CPPDEFINES"]['BSP_CFG_RTOS'] == '2':                if int(self.test_env["CPPDEFINES"]['DEMO_STACK_SIZE'], 0) > CONST_GCOV_MIN_STACK_SIZE:                    stack_size = self.test_env["CPPDEFINES"]['DEMO_STACK_SIZE']        if self.test_env["CPPDEFINES"]['BSP_CFG_RTOS'] == '2':            self.test_env["CPPDEFINES"]['DEMO_STACK_SIZE'] = stack_size            self.no_instrument_env["CPPDEFINES"]['DEMO_STACK_SIZE'] = self.test_env["CPPDEFINES"]['DEMO_STACK_SIZE']        else:            self.test_env["CPPDEFINES"]['BSP_CFG_STACK_MAIN_BYTES'] = stack_size            self.no_instrument_env["CPPDEFINES"]['BSP_CFG_STACK_MAIN_BYTES'] = self.test_env["CPPDEFINES"]['BSP_CFG_STACK_MAIN_BYTES']    def _sign_bootloader_application_image(self):        """ If a bootloader project, performs signing of the bootloader project. """        # These environment variables are required for the click package used in imgtool        self.exe_env['ENV']['LANG'] = 'C.UTF-8'        self.exe_env['ENV']['LC_ALL'] = 'C.UTF-8'        output_tmp_file = self.output_elf_file.replace('.elf', '.tmp')        output_bin_file = self.output_elf_file.replace('.elf', '.bin')        output_signed_file = self.output_elf_file.replace('.elf', '.signed.srec')        if self.project.bootloader is not None:            bootloader = self.project.bootloader            key_arg = ''            enc_key_arg = ''            if self.project.key:                key_arg = ' -k ' + self.project.key            if 'mcuboot' == bootloader.name:                header_size_arg = ' --header-size ' + bootloader.header_size                slot_size_arg = ' --slot-size ' + bootloader.slot_size                max_sectors_arg = ' --max-sectors ' + bootloader.max_sectors                align_arg = ' --align ' + bootloader.align + ' --max-align ' + bootloader.align                if 'secondary' in self.output_elf_file:                    version_arg = ' --version ' + bootloader.secondary_version                    address_arg = ' --change-addresses=' + bootloader.secondary_slot                    pad_arg = ' ' + bootloader.secondary_pad_arg                    if self.project.enc_key:                        enc_key_arg = ' --encrypt ' + self.project.enc_key                else:                    version_arg = ' --version ' + bootloader.version                    address_arg = ' --change-addresses=' + bootloader.primary_slot                    pad_arg = ' ' + bootloader.primary_pad_arg                # To prevent scons from caching signed bin files                NoCache(output_bin_file)                NoCache(output_tmp_file)                NoCache(output_signed_file)                self.exe_env.Command(output_tmp_file, self.output_srec_file, 'arm-none-eabi-objcopy --output-target=binary --input-target=srec ${SOURCE} ${TARGET}')                self.exe_env.Command(output_bin_file, output_tmp_file, 'python3 ra/mcu-tools/MCUboot/scripts/imgtool.py sign' + key_arg + enc_key_arg + header_size_arg + slot_size_arg + max_sectors_arg + version_arg + align_arg + pad_arg + ' --pad-header ${SOURCE} ${TARGET}')                self.exe_env.Command(output_signed_file, output_bin_file, 'arm-none-eabi-objcopy --output-target=srec --input-target=binary' + address_arg + ' ${SOURCE} ${TARGET}')class mcuboot():    """ Define MCUboot class to store all variables related to MCUboot signing. """    def __init__(self, bootloader_root):        self.name = bootloader_root.find('name').text        self.header_size = bootloader_root.find('header_size').text        self.slot_size = bootloader_root.find('slot_size').text        self.max_sectors = bootloader_root.find('max_sectors').text        self.align = bootloader_root.find('align').text        self.version = bootloader_root.find('version').text        self.secondary_version = bootloader_root.find('secondary_version').text        self.primary_slot = bootloader_root.find('primary_slot').text        self.secondary_slot = bootloader_root.find('secondary_slot').text        self.primary_pad_arg = bootloader_root.find('primary_pad_arg').text        self.secondary_pad_arg = bootloader_root.find('secondary_pad_arg').text        if self.secondary_pad_arg is None:            self.secondary_pad_arg = ''        if self.primary_pad_arg is None:            self.primary_pad_arg = ''class project_common():    """ Define project class to store all variables related to project. """    def __init__(self, file, xml_root=None, common_file=CONST_COMMON_PROJECT_FILE):        self.boards = []        self.bootloader = None        self.common_dirs = []        self.common_macros = {}        self.dependencies = []        self.exclude_dirs = []        self.includes = []        self.key = ''        self.enc_key = ''        self.libraries = []        self.linker_paths = []        self.linker_includes = []        self.secondary_linker_includes = []        self.linker_scripts = []        self.main_dirs = []        self.main_macro_configurations = []        self.name = ''        self.no_instrument_files = []        self.skip_compiler = []        self.srec_check = []        self.test_dirs = []        self.test_macros = {}        self.third_party_test_dirs = []        self.type = 'flat'        self.target_group = None        self.test_info_init = '{}'        self.custom_cxx_flags = defaultdict(list)        # Populate a list of primary cores using CONST_MCU_DICT        self.mcu_dict = {}        for mcu in CONST_MCU_DICT:            self.mcu_dict[mcu] = CONST_MCU_DICT[mcu]["primary_core"]        self.filename = os.path.basename(file)        self.module_name, _ = os.path.splitext(self.filename)        # Parse common project information        if common_file is not None:            common_tree = etree.parse(common_file)            common_root = common_tree.getroot()            parse_project(common_root, self)        if xml_root is not None:            parse_project(xml_root, self)class project_tz_secure(project_common):    """ Define class to store all variables related to project_tz_secure. Inherits properties of project_common. """    _x